<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/_12sdp"
    app:cardCornerRadius="@dimen/_12sdp"
    app:cardElevation="@dimen/_2sdp"
    app:cardBackgroundColor="@color/hicri_list_card_bg"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:minHeight="@dimen/_72sdp">

        <!-- Sol aksan çubuğu -->
        <View
            android:id="@+id/itemHicriAccentBar"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/accent_gold"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="@dimen/_12sdp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/itemHicriIcon"
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_32sdp"
                    android:src="@drawable/celebration"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/_10sdp">

                    <TextView
                        android:id="@+id/itemHicriName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_dark"
                        android:textSize="@dimen/_15ssp"
                        android:textStyle="bold"
                        tools:text="Kadir Gecesi"/>

                    <TextView
                        android:id="@+id/itemHicriDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_2sdp"
                        android:textColor="@color/text_grey"
                        android:textSize="@dimen/_11ssp"
                        android:maxLines="2"
                        android:ellipsize="end"
                        tools:text="Bin aydan hayırlı mübarek gece"/>

                    <TextView
                        android:id="@+id/itemHicriTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/bg_hicri_tag"
                        android:paddingHorizontal="@dimen/_8sdp"
                        android:paddingVertical="@dimen/_2sdp"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_10ssp"
                        android:visibility="gone"
                        tools:text="Kandil"
                        tools:visibility="visible"/>
                </LinearLayout>

                <!-- Sağ üst: gün kaldı -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/itemHicriDaysNum"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent_gold"
                        android:textSize="@dimen/_22ssp"
                        android:textStyle="bold"
                        tools:text="17"/>

                    <TextView
                        android:id="@+id/itemHicriDaysLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="gün kaldı"
                        android:textColor="@color/text_grey"
                        android:textSize="@dimen/_10ssp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Tarih satırı: Hicri · Miladi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/_8sdp">

                <ImageView
                    android:layout_width="@dimen/_12sdp"
                    android:layout_height="@dimen/_12sdp"
                    android:src="@drawable/calendar_hicri"/>
                <TextView
                    android:id="@+id/itemHicriHijri"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_4sdp"
                    android:textColor="@color/text_grey"
                    android:textSize="@dimen/_11ssp"
                    tools:text="26 Ramazan 1447 H"/>
                <View
                    android:layout_width="4dp"
                    android:layout_height="4dp"
                    android:layout_marginHorizontal="@dimen/_6sdp"
                    android:background="@drawable/bg_circle_grey"/>
                <TextView
                    android:id="@+id/itemHicriGregorian"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_grey"
                    android:textSize="@dimen/_11ssp"
                    tools:text="Pazartesi, 16 Mart 2026"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
