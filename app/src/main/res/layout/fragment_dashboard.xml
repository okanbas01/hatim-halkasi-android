<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/secondary_cream"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="@dimen/_90sdp">

        <!-- 1. HEADER (PROFİL VE SELAMLAMA) -->
        <LinearLayout
            android:id="@+id/headerContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/_20sdp"
            android:layout_marginTop="@dimen/_32sdp"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.cardview.widget.CardView
                android:layout_width="@dimen/_40sdp"
                android:layout_height="@dimen/_40sdp"
                app:cardCornerRadius="@dimen/_20sdp"
                app:cardBackgroundColor="@color/white_card"
                app:cardElevation="@dimen/_2sdp">

                <ImageView
                    android:id="@+id/imgProfileAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/_8sdp"
                    android:src="@drawable/ic_nav_user_islamic"
                    app:tint="@color/primary_green"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"/>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="@dimen/_12sdp">

                <TextView
                    android:id="@+id/txtGreetingTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Esselamü Aleyküm,"
                    android:textColor="@color/accent_gold"
                    android:textSize="@dimen/_11ssp"
                    android:fontFamily="serif"/>

                <TextView
                    android:id="@+id/txtDashboardName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Misafir"
                    android:textColor="@color/primary_green"
                    android:textSize="@dimen/_18ssp"
                    android:textStyle="bold"
                    android:fontFamily="serif"/>
            </LinearLayout>

            <!-- Dark/Light mode toggle: Lottie veya fallback ikon her zaman görünsün -->
            <FrameLayout
                android:id="@+id/lottieThemeToggle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="@dimen/_8sdp"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Tema değiştir (koyu/açık)"
                android:background="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:id="@+id/themeToggleFallbackIcon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/_10sdp"
                    android:src="@drawable/ic_read_moon"
                    app:tint="@color/accent_gold"
                    android:visibility="visible"
                    android:contentDescription="Tema değiştir"/>
            </FrameLayout>

            <!-- SAĞ: BİLDİRİM AYARLARI BUTONU -->
            <FrameLayout
                android:id="@+id/btnNotificationSettings"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:background="@drawable/bg_circle_green"
                android:backgroundTint="#F1F8E9"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="@dimen/_3sdp"
                    android:src="@drawable/ic_notification_bell"
                    android:layout_gravity="center"/>
            </FrameLayout>

        </LinearLayout>

        <!-- 2. NAMAZ VAKTİ KARTI -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPrayerTimes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_20sdp"
            android:layout_marginTop="@dimen/_20sdp"
            app:cardCornerRadius="@dimen/_24sdp"
            app:cardElevation="@dimen/_8sdp"
            app:cardBackgroundColor="@color/primary_green"
            app:layout_constraintTop_toBottomOf="@+id/headerContent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_prayer_card"
                android:padding="@dimen/_16sdp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/bg_pattern_islamic"
                    android:alpha="0.05"
                    android:scaleType="centerCrop"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <!-- KONUM ÇİPİ -->
                <LinearLayout
                    android:id="@+id/chipLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_location_chip"
                    android:backgroundTint="#33000000"
                    android:paddingHorizontal="@dimen/_10sdp"
                    android:paddingVertical="@dimen/_4sdp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/imgLocationStatus"
                        android:layout_width="@dimen/_12sdp"
                        android:layout_height="@dimen/_12sdp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="@color/accent_gold"/>

                    <TextView
                        android:id="@+id/txtLocationName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Konum Bulunuyor..."
                        android:textColor="#E0E0E0"
                        android:textSize="@dimen/_10ssp"
                        android:layout_marginStart="@dimen/_4sdp"/>
                </LinearLayout>

                <!-- Alt metin + Şehir Seç (varsayılan/yükleniyor durumunda) -->
                <LinearLayout
                    android:id="@+id/layoutLocationFallback"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@+id/chipLocation"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">
                    <TextView
                        android:id="@+id/txtLocationSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#B0FFFFFF"
                        android:textSize="@dimen/_9ssp"
                        android:layout_marginTop="@dimen/_4sdp"/>
                    <TextView
                        android:id="@+id/btnPrayerSelectCity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Şehir Seç"
                        android:textColor="@color/accent_gold"
                        android:textSize="@dimen/_10ssp"
                        android:textStyle="bold"
                        android:padding="@dimen/_6sdp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground"
                        android:layout_marginTop="@dimen/_4sdp"/>
                </LinearLayout>

                <!-- BAŞLIK -->
                <TextView
                    android:id="@+id/lblNextPrayer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vaktin Çıkmasına Kalan"
                    android:textColor="@color/accent_gold"
                    android:textSize="@dimen/_11ssp"
                    android:fontFamily="serif"
                    android:layout_marginTop="@dimen/_20sdp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/layoutLocationFallback"/>

                <!-- VAKİT İSMİ -->
                <TextView
                    android:id="@+id/txtNextPrayerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/_36ssp"
                    android:textStyle="bold"
                    android:fontFamily="serif"
                    android:letterSpacing="0.1"
                    android:layout_marginTop="@dimen/_8sdp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/lblNextPrayer"/>

                <!-- SAAT -->
                <TextView
                    android:id="@+id/txtNextPrayerTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--:--"
                    android:textColor="#FFFFFF"
                    android:textSize="@dimen/_48ssp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-light"
                    android:includeFontPadding="false"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/txtNextPrayerName"/>

                <!-- AÇIKLAMA -->
                <TextView
                    android:id="@+id/txtPrayerDesc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="vakit açıklaması"
                    android:textColor="#80FFFFFF"
                    android:textSize="@dimen/_12ssp"
                    android:fontFamily="serif"
                    android:layout_marginTop="@dimen/_minus4sdp"
                    app:layout_constraintTop_toBottomOf="@+id/txtNextPrayerTime"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- GERİ SAYIM -->
                <LinearLayout
                    android:id="@+id/layoutCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="@dimen/_16sdp"
                    app:layout_constraintTop_toBottomOf="@+id/txtPrayerDesc"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <View
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="2dp"
                        android:background="@color/accent_gold"
                        android:layout_marginEnd="@dimen/_8sdp"/>

                    <TextView
                        android:id="@+id/txtCountdown"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- saat -- dakika"
                        android:textColor="@color/accent_gold"
                        android:textSize="@dimen/_11ssp"
                        android:textStyle="bold"/>

                    <View
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="2dp"
                        android:background="@color/accent_gold"
                        android:layout_marginStart="@dimen/_8sdp"/>
                </LinearLayout>

                <!-- ALT VAKİTLER -->
                <LinearLayout
                    android:id="@+id/layoutPrayerRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="6"
                    android:layout_marginTop="@dimen/_24sdp"
                    app:layout_constraintTop_toBottomOf="@+id/layoutCountdown"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="İmsak"
                            android:textColor="#80FFFFFF"
                            android:textSize="@dimen/_9ssp"/>
                        <TextView
                            android:id="@+id/timeFajr"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="@dimen/_11ssp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Güneş"
                            android:textColor="#80FFFFFF"
                            android:textSize="@dimen/_9ssp"/>
                        <TextView
                            android:id="@+id/timeSunrise"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="@dimen/_11ssp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Öğle"
                            android:textColor="#80FFFFFF"
                            android:textSize="@dimen/_9ssp"/>
                        <TextView
                            android:id="@+id/timeDhuhr"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="@dimen/_11ssp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="İkindi"
                            android:textColor="#80FFFFFF"
                            android:textSize="@dimen/_9ssp"/>
                        <TextView
                            android:id="@+id/timeAsr"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="@dimen/_11ssp"/>
                    </LinearLayout>

                    <!-- ✅ AKŞAM -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Akşam"
                            android:textColor="#80FFFFFF"
                            android:textSize="@dimen/_9ssp"/>
                        <TextView
                            android:id="@+id/timeMaghrib"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="@dimen/_11ssp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Yatsı"
                            android:textColor="#80FFFFFF"
                            android:textSize="@dimen/_9ssp"/>
                        <TextView
                            android:id="@+id/timeIsha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="@dimen/_11ssp"/>
                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardQuranGuide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_20sdp"
            android:layout_marginTop="@dimen/_12sdp"
            android:visibility="gone"
            android:saveEnabled="false"
            app:cardCornerRadius="@dimen/_16sdp"
            app:cardElevation="@dimen/_3sdp"
            app:strokeWidth="1dp"
            app:strokeColor="#E8E0D0"
            app:cardBackgroundColor="#FFFDF5"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@+id/cardPrayerTimes">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/_12sdp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/qgIconContainer"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    app:cardCornerRadius="@dimen/_10sdp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white_card"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_card_border"/>

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="@dimen/_8sdp"
                        android:src="@drawable/ic_quran_guide_chat"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:id="@+id/qgTextArea"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/_12sdp"
                    android:layout_marginEnd="@dimen/_12sdp"
                    app:layout_constraintStart_toEndOf="@+id/qgIconContainer"
                    app:layout_constraintEnd_toStartOf="@+id/qgArrow"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:id="@+id/txtQuranGuideTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gönlünü Aç"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:textSize="@dimen/_12ssp"
                        android:fontFamily="serif"/>

                    <TextView
                        android:id="@+id/txtQuranGuideSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soru sor, konu aç, içini dök"
                        android:textSize="@dimen/_10ssp"
                        android:textColor="@color/text_grey"
                        android:layout_marginTop="@dimen/_2sdp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/qgArrow"
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:background="@drawable/bg_play_button"
                    android:gravity="center"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <ImageView
                        android:layout_width="@dimen/_12sdp"
                        android:layout_height="@dimen/_12sdp"
                        android:src="@drawable/ic_arrow_right_small"
                        app:tint="@color/white"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. KUR'AN BÖLÜMÜ -->
        <LinearLayout
            android:id="@+id/sectionQuran"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/_18sdp"
            android:paddingHorizontal="@dimen/_20sdp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@+id/cardQuranGuide">

            <ImageView
                android:layout_width="@dimen/_36sdp"
                android:layout_height="@dimen/_36sdp"
                android:src="@drawable/ic_nav_quran_color"
                android:padding="@dimen/_8sdp"
                android:contentDescription="Kur'an-ı Kerim" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kur'an-ı Kerim"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold"
                android:textColor="@color/primary_green"
                android:layout_marginStart="@dimen/_8sdp"
                android:fontFamily="serif"/>
        </LinearLayout>

        <!-- Kaldığın Yerden Devam Et -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardContinueReading"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_20sdp"
            android:layout_marginTop="@dimen/_8sdp"
            app:cardCornerRadius="@dimen/_16sdp"
            app:cardBackgroundColor="@color/white_card"
            app:cardElevation="@dimen/_3sdp"
            android:clickable="true"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@+id/sectionQuran">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/_12sdp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/iconContainer"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    app:cardCornerRadius="@dimen/_8sdp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white_card"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_card_border"/>

                    <ImageView
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:src="@drawable/ic_resume_reading"
                        android:padding="@dimen/_8sdp" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/_12sdp"
                    android:layout_marginEnd="@dimen/_12sdp"
                    app:layout_constraintStart_toEndOf="@+id/iconContainer"
                    app:layout_constraintEnd_toStartOf="@+id/btnPlay"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <TextView
                        android:id="@+id/txtCardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hatimlerine Git"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:textSize="@dimen/_12ssp"
                        android:fontFamily="serif"/>

                    <TextView
                        android:id="@+id/txtCardSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kaldığın yerden devam et"
                        android:textSize="@dimen/_10ssp"
                        android:textColor="@color/text_grey"
                        android:layout_marginTop="@dimen/_2sdp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnPlay"
                    android:layout_width="@dimen/_30sdp"
                    android:layout_height="@dimen/_30sdp"
                    android:background="@drawable/bg_play_button"
                    android:gravity="center"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <ImageView
                        android:layout_width="@dimen/_12sdp"
                        android:layout_height="@dimen/_12sdp"
                        android:src="@drawable/ic_media_play"
                        app:tint="@color/white"/>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- GÜNLÜK SERİ VE MİKRO HEDEF (Hafif, Performans Odaklı) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDailyProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_20sdp"
            android:layout_marginTop="@dimen/_12sdp"
            app:cardCornerRadius="@dimen/_12sdp"
            app:cardBackgroundColor="@color/white_card"
            app:cardElevation="@dimen/_2sdp"
            app:layout_constraintTop_toBottomOf="@+id/cardContinueReading"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/_12sdp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtStreak"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="📿 0 Günlük Okuma Serin"
                    android:textSize="@dimen/_11ssp"
                    android:textColor="@color/primary_green"
                    android:textStyle="bold"/>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#E0E0E0"
                    android:layout_marginHorizontal="@dimen/_8sdp"/>

                <TextView
                    android:id="@+id/txtDailyGoal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bugün: 0 sayfa"
                    android:textSize="@dimen/_11ssp"
                    android:textColor="@color/text_grey"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 4. GÜNÜN SÖZÜ -->
        <LinearLayout
            android:id="@+id/sectionDaily"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/_16sdp"
            android:paddingHorizontal="@dimen/_20sdp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@+id/cardDailyProgress">

            <ImageView
                android:layout_width="@dimen/_16sdp"
                android:layout_height="@dimen/_16sdp"
                android:src="@drawable/ic_star_selcuk"
                app:tint="@color/accent_gold"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Günün Sözü"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold"
                android:textColor="@color/primary_green"
                android:layout_marginStart="@dimen/_8sdp"
                android:fontFamily="serif"/>
        </LinearLayout>

        <!-- 5. GÜNÜN SÖZÜ KARTI -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDailyVerse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_20sdp"
            android:layout_marginTop="@dimen/_12sdp"
            app:cardCornerRadius="@dimen/_16sdp"
            app:cardElevation="@dimen/_3sdp"
            app:cardBackgroundColor="#FFFDF5"
            app:strokeColor="#E8E0D0"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@+id/sectionDaily">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/_16sdp">

                <ImageView
                    android:layout_width="@dimen/_18sdp"
                    android:layout_height="@dimen/_18sdp"
                    android:src="@drawable/ic_corner_decoration"
                    app:tint="#D7CCC8"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <ImageView
                    android:layout_width="@dimen/_18sdp"
                    android:layout_height="@dimen/_18sdp"
                    android:src="@drawable/ic_corner_decoration"
                    app:tint="#D7CCC8"
                    android:rotation="90"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

                <TextView
                    android:id="@+id/txtQuoteIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❝"
                    android:textSize="@dimen/_30ssp"
                    android:textColor="#D7CCC8"
                    android:fontFamily="serif"
                    android:layout_marginTop="@dimen/_4sdp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <TextView
                    android:id="@+id/txtDailyVerse"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Yükleniyor..."
                    android:textSize="@dimen/_12ssp"
                    android:textColor="#37474F"
                    android:fontFamily="serif"
                    android:textAlignment="center"
                    android:lineSpacingExtra="@dimen/_4sdp"
                    android:layout_marginTop="@dimen/_4sdp"
                    android:layout_marginHorizontal="@dimen/_12sdp"
                    app:layout_constraintTop_toBottomOf="@+id/txtQuoteIcon"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <LinearLayout
                    android:id="@+id/layoutDivider"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="@dimen/_12sdp"
                    app:layout_constraintTop_toBottomOf="@+id/txtDailyVerse"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <View
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="1dp"
                        android:background="#D7CCC8"/>
                    <View
                        android:layout_width="@dimen/_4sdp"
                        android:layout_height="@dimen/_4sdp"
                        android:layout_marginHorizontal="@dimen/_6sdp"
                        android:background="@drawable/bg_circle_gold"/>
                    <View
                        android:layout_width="@dimen/_30sdp"
                        android:layout_height="1dp"
                        android:background="#D7CCC8"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtDailySource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textSize="@dimen/_11ssp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_green"
                    android:layout_marginTop="@dimen/_8sdp"
                    app:layout_constraintTop_toBottomOf="@+id/layoutDivider"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <ImageView
                    android:layout_width="@dimen/_18sdp"
                    android:layout_height="@dimen/_18sdp"
                    android:src="@drawable/ic_corner_decoration"
                    app:tint="#D7CCC8"
                    android:rotation="270"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

                <ImageView
                    android:layout_width="@dimen/_18sdp"
                    android:layout_height="@dimen/_18sdp"
                    android:src="@drawable/ic_corner_decoration"
                    app:tint="#D7CCC8"
                    android:rotation="180"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 6. HİCRİ TAKVİM BAŞLIĞI (kart dışında, Günün Sözü gibi) -->
        <LinearLayout
            android:id="@+id/sectionHicri"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/_16sdp"
            android:paddingHorizontal="@dimen/_20sdp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@+id/cardDailyVerse">

            <ImageView
                android:layout_width="@dimen/_16sdp"
                android:layout_height="@dimen/_16sdp"
                android:src="@drawable/calendar"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hicri Takvim"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold"
                android:textColor="@color/primary_green"
                android:layout_marginStart="@dimen/_8sdp"
                android:fontFamily="serif"/>
        </LinearLayout>

        <!-- Hicri Takvim kartı (Günün Sözü kartı ile aynı yatay genişlik) -->
        <include
            android:id="@+id/includeHicriCard"
            layout="@layout/card_hicri_takvim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_20sdp"
            android:layout_marginTop="@dimen/_12sdp"
            app:layout_constraintTop_toBottomOf="@+id/sectionHicri"/>

        <!-- Uygulamayı Destekle (rewarded video – sadece destek, reklamsızlık ödülü yok) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSupportAppDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_20sdp"
            android:layout_marginTop="@dimen/_12sdp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/card_background_light"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:layout_constraintTop_toBottomOf="@+id/includeHicriCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/support_app"
                    android:contentDescription="@null"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:id="@+id/txtSupportAppTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Uygulamayı Destekle 🤍"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="@color/text_dark"/>
                    <TextView
                        android:id="@+id/txtSupportAppDescription"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/support_app_description"
                        android:textSize="13sp"
                        android:textColor="@color/text_grey"
                        android:layout_marginTop="2dp"/>
                    <TextView
                        android:id="@+id/txtSupportAppTodayCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bugün 0 kez destek oldunuz"
                        android:textSize="13sp"
                        android:textColor="@color/text_grey"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Banner: Ana sayfa en alt, scroll ile görünür (sticky değil) -->
        <include
            android:id="@+id/includeAdBanner"
            layout="@layout/ad_banner_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_12sdp"
            app:layout_constraintTop_toBottomOf="@+id/cardSupportAppDashboard"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
