<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.DenemeProjesi" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent_gold</item>
        <item name="colorOnSecondary">@color/text_dark</item>
        <item name="colorTertiary">@color/accent_gold</item>
        <item name="colorOnTertiary">@color/text_dark</item>

        <item name="android:colorBackground">@color/bg_cream</item>
        <item name="android:windowBackground">@color/bg_cream</item>
        <item name="colorSurface">@color/white_card</item>
        <item name="colorOnSurface">@color/text_dark</item>
        <item name="colorOnBackground">@color/text_dark</item>
        <item name="colorSurfaceVariant">@color/card_background_light</item>
        <item name="colorOnSurfaceVariant">@color/text_grey</item>

        <item name="android:statusBarColor">@color/header_green</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:navigationBarColor">@color/white_card</item>

        <item name="android:textColorPrimary">@color/text_dark</item>
        <item name="android:textColorSecondary">@color/text_grey</item>

        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Material3.MaterialAlertDialog</item>
        <item name="alertDialogTheme">@style/ThemeOverlay.Material3.MaterialAlertDialog</item>
        <item name="materialButtonStyle">@style/Widget.Material3.Button</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="Theme.App.Splash" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/bg_intro</item>
        <item name="android:statusBarColor">@color/header_green</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="TabTextStyle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="textAllCaps">false</item>
        <item name="android:textColor">@color/text_grey</item>
    </style>

    <style name="MyBottomNavStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="android:background">@color/white_card</item>
        <item name="elevation">0dp</item>
    </style>
</resources>
